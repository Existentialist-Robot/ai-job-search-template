# Job Search Workspace — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Adzuna API (optional but recommended) ─────────────────────────────────────
# Provides structured JSON job listings with salary data across Canada.
# Register free at: https://developer.adzuna.com
# Free tier: ~250 calls/day
# MCP server available: github.com/folathecoder/adzuna-job-search-mcp
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here

# ── Jooble API (optional) ─────────────────────────────────────────────────────
# Broad aggregator (70+ countries incl. Canada); aggregates Job Bank.
# Free key on request at: https://jooble.org/api/about
JOOBLE_API_KEY=your_key_here

# ── GitHub (optional — for automated tracker commits) ─────────────────────────
# Only needed if you want Claude Code to push tracker updates automatically.
GITHUB_TOKEN=your_github_token_here

# ── Notes ─────────────────────────────────────────────────────────────────────
# The core workflow (WebSearch + WebFetch scraping) requires NO API keys.
# Add Adzuna first — it's the biggest step-change for search quality.
# Canva MCP is configured in Claude Code settings (not here).
